# MongoDB
MONGO_USER=admin
MONGO_PASSWORD=your_mongo_password_here
MONGO_EXPRESS_USER=your_mongo_express_username_here
MONGO_EXPRESS_PASS=your_mongo_express_password_here
MONGO_URL=mongodb://admin:your_mongo_password_here@localhost:27017

# MotherDuck
MOTHERDUCK_TOKEN=your_motherduck_token_here

# Airflow
AIRFLOW_UID=50000
AIRFLOW_GID=0
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=your_airflow_password_here
AIRFLOW_FERNET_KEY=your_fernet_key_here
AIRFLOW_JWT_SECRET=your_jwt_secret_here

# Data paths
RAW_DATA_PATH=datasets
